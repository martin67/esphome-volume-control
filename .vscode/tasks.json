{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Bootstrap project (venv + deps)",
            "type": "shell",
            "command": "python",
            "args": [
                "${workspaceFolder}/scripts/bootstrap.py"
            ],
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "Generate diagram",
            "type": "shell",
            "command": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
            "args": [
                "${file}"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}